        <link rel="stylesheet" href="./assets/css/chatv25.css" />

<!-- Small Chatbot -->
<div class="chat-pop-sm">
    <button id="chat-pop-sm-close" type="button" class="close" data-dismiss="chat-pop-sm" aria-label="Close">
        <span aria-hidden="true">×</span>
