<script>
function bindFormSubmit() {

  let fpPromise = null; // lazy initialized

  $('form#pardotForm').off('submit').on('submit', function (e) {
    e.preventDefault();

    const $form = $(this);
    const $submitBtn = $form.find('button[type="submit"], input[type="submit"]');
    const $errorSpan = $form.find('.errorMessage');

    $submitBtn.prop('disabled', true);
    $errorSpan.text('');
    clearTimeout($errorSpan.data('timeoutId'));

    $.ajax({
      url: 'ipcheck.php',
      type: 'GET',
      dataType: 'json',

      success: function (data) {
        if (!data.status) {
          showError(data.message);
          return;
        }

        // 🔹 Lazy-load FingerprintJS ONLY when needed
        if (!fpPromise) {
          fpPromise = import('https://fpjscdn.net/v3/rmevazJvk6HdBPJpRXuX')
            .then(FingerprintJS => FingerprintJS.load({ region: 'ap' }));
        }

        fpPromise
          .then(fp => fp.get())
          .then(result => {
            submitWithDeviceId(result.visitorId);
          })
          .catch(err => {
            console.error('FingerprintJS error:', err);
            submitWithDeviceId('fallback-' + Date.now());
          });
      },

      error: function () {
        showError('An unexpected error occurred.');
      }
    });

    function submitWithDeviceId(deviceId) {
      let $deviceIdField = $form.find('input[name="device_id"]');

      if ($deviceIdField.length === 0) {
        $form.append('<input type="hidden" name="device_id">');
        $deviceIdField = $form.find('input[name="device_id"]');
      }

      $deviceIdField.val(deviceId);

      console.log('Device ID:', deviceId);

      // Submit safely
      $form.off('submit');
      $form.submit();
    }

    function showError(message) {
      $errorSpan.text(message);

      const timeoutId = setTimeout(() => {
        $errorSpan.fadeOut(400, function () {
          $(this).text('').show();
        });
      }, 5000);

      $errorSpan.data('timeoutId', timeoutId);
      $submitBtn.prop('disabled', false);
    }
  });
}



// Bind when document is ready
$(document).ready(function() {
    bindFormSubmit();
});

// Also bind when coming back from bfcache
$(window).on('pageshow', function(event) {
    if (event.originalEvent.persisted) {
        bindFormSubmit();
    }
});
</script>

